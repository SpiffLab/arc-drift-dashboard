// Change Tracking detail — individual change events. Filter by ConfigChangeType in the workbook.
ConfigurationChange
| where TimeGenerated {TimeRange}
| project TimeGenerated, Computer, ConfigChangeType, ChangeCategory,
          FieldsChanged, SvcName, SvcDisplayName, SvcState, SvcPreviousState,
          FileSystemPath, Size, Sha256, SoftwareName, Previous, Current,
          RegistryKey, ValueName, ValueData
| order by TimeGenerated desc
